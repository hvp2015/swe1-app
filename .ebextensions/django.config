option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: mysite.wsgi:application
  aws:elasticbeanstalk:application:
    Application Healthcheck Path: /
  aws:elb:healthcheck:
    HealthyThreshold: 2
    Interval: 10
    Timeout: 5
    UnhealthyThreshold: 2

container_commands:
  01_migrate:
    command: "python manage.py migrate --noinput"
    leader_only: true
  02_collectstatic:
    command: "python manage.py collectstatic --noinput"
  03_create_superuser:
    command: "python manage.py createsuperuser --noinput --username pimpalshende --email harshalpimpalshwnde@gmail.com || true"
    leader_only: true